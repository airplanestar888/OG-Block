{
  "manifest_version": 3,
  "name": "Base Culture Score",
  "version": "0.1.0",
  "description": "Display verified Base NFT score and OG rank on x.com profiles.",
  "permissions": ["storage"],
  "host_permissions": ["https://x.com/*", "http://localhost:3000/*", "https://*.vercel.app/*"],
  "content_scripts": [
    {
      "matches": ["https://x.com/*"],
      "js": ["content.js"],
      "css": ["styles.css"],
      "run_at": "document_idle"
    }
  ],
  "options_page": "options.html"
}
